#include<stdio.h>
int main()
{
   int mark;
   printf("Enter the mark of students");
   scanf("%d",&mark);
   if(mark>=90)
      printf("The grade of student is A");
   else if(mark>=80)
      printf("The grade of student is B");
   else if(mark>=70)
      printf("The grade of student is C");
   else if(mark>=60)
      printf("The grade of student is D");
   else if(mark>=50)
      printf("The gade of student is E");
   else
      printf("The student fail");
   return 0;
}
