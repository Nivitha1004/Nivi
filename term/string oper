#include <iostream>
#include <cstring>
class StringOp
{
    char str[100];

public:
    StringOp(const char* input)
    {
        strcpy(str, input);
    }
    int getLength()
    {
        int len = 0;
        while (str[len] != '\0')
        {
            len++;
        }
        return len;
    }
    void reverseString()
    {
        int n = getLength();
        for (int i = 0; i < n / 2; i++)
        {
            char temp = str[i];
            str[i] = str[n - i - 1];
            str[n - i - 1] = temp;
        }
        std::cout << "Reversed string: " << str << std::endl;
    }
    bool isPalindrome()
    {
        int n = getLength();
        for (int i = 0; i < n / 2; i++)
        {
            if (str[i] != str[n - i - 1])
            {
                return false;
            }
        }
        return true;
    }
};

int main()
{
    StringOp op("computer");

    std::cout << "Length: " << op.getLength() << std::endl;

    if (op.isPalindrome())
        std::cout << "It is a palindrome" << std::endl;
    else
        std::cout << "Not a palindrome" << std::endl;

    op.reverseString();

    return 0;
}
