#include <iostream>
#include <set>
#include <algorithm>

using namespace std;

int main() {
    int q;
    cin >> q; // Read number of queries
    set<int> s; // Create an empty set of integers
    
    for(int i = 0; i < q; i++) {
        int type, x;
        cin >> type >> x; // Read query type and value
        
        if (type == 1) {
            // Type 1: Add an element x to the set
            s.insert(x); 
        } 
        else if (type == 2) {
            // Type 2: Delete an element x from the set
            s.erase(x); 
        } 
        else if (type == 3) {
            // Type 3: Check if x is present in the set
            if (s.find(x) != s.end()) {
                cout << "Yes" << endl;
            } else {
                cout << "No" << endl;
            }
        }
    }
    return 0;
}
