#include <cmath>
#include <cstdio>
#include <vector>
#include <iostream>
#include <algorithm>
using namespace std;


int main() {
     int n;
    cin >> n; // Read the number of integers
    
    vector<int> v;
    for(int i = 0; i < n; i++) {
        int x;
        cin >> x;
        v.push_back(x); // Store integers in the vector
    }
    
    // Sort the vector in ascending order
    sort(v.begin(), v.end());
    
    // Print the sorted elements
    for(int i = 0; i < v.size(); i++) {
        cout << v[i] << " ";
    }
    return 0;
}
